APP_NAME=Enterprise AI Agent Platform
APP_VERSION=1.1.0
APP_ENV=demo
DEBUG=false
ALLOW_CREATE_ALL=false

# SQLite persistence. Docker default stores data in ./backend/data.
DATABASE_URL=sqlite:////app/data/enterprise_ai_agent.db
# PostgreSQL production example:
# DATABASE_URL=postgresql://agent:agent_password@postgres:5432/agentdb

# Auth/RBAC
AUTH_ENABLED=false
PUBLIC_ENGINEER_REGISTRATION_ENABLED=false
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
# Optional one-time administrator bootstrap. Never commit real values.
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=

# Chroma vector database. Docker Compose service name is "chromadb".
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_HOST_PORT=8001
CHROMA_COLLECTION_NAME=knowledge_chunks

# Docker backend loads LLM runtime settings from backend/.env.
# Keep real API keys in backend/.env only; do not duplicate them in root .env.
# Recommended backend/.env values for a real OpenAI-compatible provider:
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=
# LLM_TIMEOUT_SECONDS=30
# LLM_MAX_RETRIES=2
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=1200
# LLM_JSON_MODE=true
# Mock is allowed only when explicitly configured in development/test.

# Ollama local models, for example qwen2.5 or qwen3.
OLLAMA_BASE_URL=http://host.docker.internal:11434

AGENT_RUNTIME_ENABLED=false
EMBEDDING_MODEL_PATH=/app/models/bge-small-zh-v1.5

# Optional RAG reranker. Disabled by default to keep local/demo startup light.
# Enable after preparing the reranker model locally or allowing model download.
RERANKER_ENABLED=false
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_MODEL_PATH=
RERANKER_CANDIDATE_K=20
RERANKER_BATCH_SIZE=16

# PostgreSQL container
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_password
POSTGRES_DB=agentdb
